---
/**
 * ReadingProgress — thin bar at top of viewport that fills as the user
 * scrolls the article. Hidden on non-article pages.
 */
---

<div class="reading-progress" data-reading-progress aria-hidden="true">
  <div class="reading-progress-fill"></div>
</div>

<script>
  const bar = document.querySelector('[data-reading-progress] .reading-progress-fill');
  if (bar) {
    let ticking = false;
    const update = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? Math.min(100, Math.max(0, (h.scrollTop / max) * 100)) : 0;
      (bar as HTMLElement).style.width = pct + '%';
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
    update();
  }
</script>
