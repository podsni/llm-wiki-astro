---
/**
 * Search modal. Uses native <dialog> for focus trap, escape handling,
 * light-dismiss, and proper a11y. Fuse.js loaded on first open.
 */
---

<dialog class="search-modal" data-search-modal aria-label="Search the wiki">
  <form class="search-form" method="dialog">
    <div class="search-modal-header">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="search"
        class="search-input"
        placeholder="Search articles, concepts, tags…"
        data-search-input
        autocomplete="off"
        spellcheck="false"
        inputmode="search"
        aria-label="Search query"
      />
      <button class="search-modal-close" type="button" data-search-close aria-label="Close search">
        <kbd>esc</kbd>
      </button>
    </div>
    <div class="search-results" data-search-results role="listbox" aria-label="Search results">
      <div class="search-empty">
        <p>Type at least 2 characters to search.</p>
        <p class="search-empty-hint">Press <kbd>↑</kbd> <kbd>↓</kbd> to navigate, <kbd>↵</kbd> to open, <kbd>esc</kbd> to close.</p>
      </div>
    </div>
  </form>
</dialog>

<script>
  import Fuse from 'fuse.js';

  const dialog = document.querySelector<HTMLDialogElement>('[data-search-modal]');
  const input = document.querySelector<HTMLInputElement>('[data-search-input]');
  const results = document.querySelector<HTMLElement>('[data-search-results]');
  const openers = document.querySelectorAll<HTMLElement>('[data-search-open]');
  const closers = document.querySelectorAll<HTMLElement>('[data-search-close]');
  const main = document.querySelector<HTMLElement>('main');

  let fuse: Fuse<any> | null = null;
  let idx: any[] = [];
  let selectedIdx = 0;
  let visibleResults: any[] = [];
  let lastFocus: HTMLElement | null = null;

  async function loadIndex() {
    if (fuse) return;
    try {
      const res = await fetch('/search-index.json');
      idx = await res.json();
      fuse = new Fuse(idx, {
        keys: [
          { name: 'title', weight: 0.5 },
          { name: 'aliases', weight: 0.2 },
          { name: 'description', weight: 0.15 },
          { name: 'tags', weight: 0.1 },
          { name: 'body', weight: 0.05 },
        ],
        threshold: 0.35,
        minMatchCharLength: 2,
      });
    } catch (err) {
      console.error('Search index failed to load', err);
    }
  }

  function open() {
    if (!dialog || !input) return;
    lastFocus = document.activeElement as HTMLElement;
    if (typeof dialog.showModal === 'function') {
      dialog.showModal();
    } else {
      dialog.setAttribute('open', '');
    }
    main?.setAttribute('inert', '');
    document.body.style.overflow = 'hidden';
    loadIndex();
    requestAnimationFrame(() => input.focus());
  }

  function close() {
    if (!dialog || !input) return;
    if (typeof dialog.close === 'function') dialog.close();
    else dialog.removeAttribute('open');
    main?.removeAttribute('inert');
    document.body.style.overflow = '';
    input.value = '';
    renderResults([]);
    if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
  }

  function renderResults(matches: any[]) {
    if (!results) return;
    if (matches.length === 0) {
      if (input && input.value && input.value.length >= 2) {
        results.innerHTML = '<div class="search-empty"><p>No matches for <q></q>.</p><p class="search-empty-hint">Try a different keyword, or browse the <a href="/az">A–Z index</a>.</p></div>';
        const q = results.querySelector('q');
        if (q) q.textContent = input.value;
      } else {
        results.innerHTML = `
          <div class="search-empty">
            <p>Type at least 2 characters to search.</p>
            <p class="search-empty-hint">Press <kbd>↑</kbd> <kbd>↓</kbd> to navigate, <kbd>↵</kbd> to open, <kbd>esc</kbd> to close.</p>
          </div>
        `;
      }
      visibleResults = [];
      return;
    }
    visibleResults = matches;
    selectedIdx = 0;
    results.innerHTML = matches.slice(0, 20).map((m, i) => `
      <a class="search-result ${i === 0 ? 'active' : ''}" href="${m.item.url}" data-idx="${i}" role="option" aria-selected="${i === 0}">
        <span class="search-result-title">${escapeHtml(m.item.title)}</span>
        <span class="search-result-meta">${m.item.collection} · ${m.item.category || 'uncategorized'}${m.item.tags?.length ? ' · ' + m.item.tags.slice(0, 3).map((t: string) => '#' + t).join(' ') : ''}</span>
        ${m.item.description ? `<span class="search-result-description">${escapeHtml(m.item.description)}</span>` : ''}
      </a>
    `).join('');
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]!);
  }

  openers.forEach((o) => o.addEventListener('click', (e) => { e.preventDefault(); open(); }));
  closers.forEach((c) => c.addEventListener('click', (e) => { e.preventDefault(); close(); }));

  // Light-dismiss: click on backdrop closes (the dialog itself, not its content).
  if (dialog) {
    dialog.addEventListener('click', (e) => {
      // If the click is on the dialog element (which stretches to the full viewport
      // when opened via showModal), close. But clicks on form/content should NOT close.
      const rect = (dialog.querySelector('.search-form') as HTMLElement)?.getBoundingClientRect();
      if (rect && (e.clientX < rect.left || e.clientX > rect.right || e.clientY < rect.top || e.clientY > rect.bottom)) {
        close();
      }
    });
    // Native dialog: 'cancel' fires on Esc; close our state too.
    dialog.addEventListener('close', () => {
      main?.removeAttribute('inert');
      document.body.style.overflow = '';
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      if (dialog?.open) close();
      else open();
      return;
    }
    if (!dialog?.open) return;
    if (e.key === 'ArrowDown' && visibleResults.length > 0) {
      e.preventDefault();
      selectedIdx = Math.min(selectedIdx + 1, visibleResults.length - 1);
      updateSelection();
    }
    if (e.key === 'ArrowUp' && visibleResults.length > 0) {
      e.preventDefault();
      selectedIdx = Math.max(selectedIdx - 1, 0);
      updateSelection();
    }
    if (e.key === 'Enter' && visibleResults[selectedIdx]) {
      e.preventDefault();
      window.location.href = visibleResults[selectedIdx].item.url;
    }
  });

  function updateSelection() {
    if (!results) return;
    const items = results.querySelectorAll('.search-result');
    items.forEach((el, i) => {
      const active = i === selectedIdx;
      el.classList.toggle('active', active);
      el.setAttribute('aria-selected', active ? 'true' : 'false');
      if (active) (el as HTMLElement).scrollIntoView({ block: 'nearest' });
    });
  }

  if (input) {
    input.addEventListener('input', async () => {
      await loadIndex();
      if (!fuse) return;
      const q = input.value.trim();
      if (q.length < 2) { renderResults([]); return; }
      const matches = fuse.search(q, { limit: 20 });
      renderResults(matches);
    });
  }
</script>
