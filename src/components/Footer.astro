---
import { getAllEntries } from '../utils/content';

interface Props {
  totalArticles?: number;
}
const { totalArticles = 0 } = Astro.props;
const year = new Date().getFullYear();
const buildDate = new Date().toISOString().split('T')[0];
const totalTags = (await getAllEntries()).reduce((set, e) => {
  for (const t of e.entry.data.tags) set.add(t);
  return set;
}, new Set<string>()).size;
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-stats">
      <div class="site-footer-stat">
        <strong>{totalArticles}</strong>
        <span>articles</span>
      </div>
      <div class="site-footer-stat">
        <strong>{totalTags}</strong>
        <span>tags</span>
      </div>
      <div class="site-footer-stat">
        <strong>CC BY-SA 4.0</strong>
        <span>license</span>
      </div>
      <div class="site-footer-stat">
        <strong>{buildDate}</strong>
        <span>last build</span>
      </div>
    </div>
    <div class="site-footer-tagline">
      <strong>LLM Wiki</strong> — a personal knowledge base. Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>. Inspired by <a href="https://tolkiengateway.net" target="_blank" rel="noopener">Tolkien Gateway</a> and the digital garden tradition.
    </div>
    <div class="site-footer-links">
      <a href="/rss.xml">RSS</a> · <a href="/sitemap-index.xml">Sitemap</a> · <a href="/about">About</a> · <a href="/az">A–Z</a> · <a href="/random">Random</a>
    </div>
    <div class="site-footer-meta">© {year}</div>
  </div>
</footer>

