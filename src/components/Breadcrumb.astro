---
interface Props {
  collection: string;
  collectionLabel: string;
  title: string;
}

const { collection, collectionLabel, title } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span class="breadcrumb-sep">›</span>
  <a href={`/${collection}`}>{collectionLabel}</a>
  <span class="breadcrumb-sep">›</span>
  <span>{title}</span>
</nav>
