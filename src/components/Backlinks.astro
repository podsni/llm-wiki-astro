---
import { computeBacklinks, getEntryUrl } from '../utils/content';
import { formatDate } from '../utils/format';

interface Props {
  slug: string;
  collection: string;
}

const { slug, collection } = Astro.props;
const all = await computeBacklinks();
const key = `${collection}/${slug}`;
const items = all.get(key) ?? [];
---

{items.length > 0 && (
  <section class="article-section">
    <h2>Articles that mention this</h2>
    <p class="text-soft" style="font-size: var(--fs-sm); margin-bottom: var(--sp-3);">
      These pages link to <code>{collection}/{slug}</code>.
    </p>
    <ul style="list-style: none; padding: 0;">
      {items.map(({ collection: srcCollection, entry: srcEntry }) => (
        <li style="padding: var(--sp-3) 0; border-bottom: 1px solid var(--color-border-soft);">
          <a class="list-item" href={getEntryUrl(srcCollection, srcEntry.id)}>
            <span class="list-item-title">{srcEntry.data.title}</span>
            {srcEntry.data.description && <span class="list-item-description">{srcEntry.data.description}</span>}
            <span class="list-item-meta">
              {srcCollection} · {formatDate(srcEntry.data.date)}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
