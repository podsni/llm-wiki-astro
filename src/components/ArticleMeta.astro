---
import { formatDate } from '../utils/format';

interface Props {
  entry: any;
  minutes: number;
}

const { entry, minutes } = Astro.props;
const updatedDate = entry.data.updated && entry.data.updated?.valueOf() !== entry.data.date?.valueOf()
  ? formatDate(entry.data.updated)
  : null;
---

<div class="article-meta">
  <span title="Created">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
    <span class="article-meta-date">{formatDate(entry.data.date)}</span>
  </span>
  {updatedDate && (
    <span title="Last updated" class="article-meta-updated">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>
      <span>updated {updatedDate}</span>
    </span>
  )}
  <span title="Estimated reading time" class="article-meta-time">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
    <span>{minutes} min</span>
  </span>
  {entry.data.category && entry.data.category !== 'uncategorized' && (
    <span class="article-meta-category">
      <a href={`/category/${entry.data.category}`}>{entry.data.category}</a>
    </span>
  )}
</div>

{entry.data.tags && entry.data.tags.length > 0 && (
  <div class="tag-list article-meta-tags">
    {entry.data.tags.map((t: string) => <a class="tag" href={`/tag/${t}`}>#{t}</a>)}
  </div>
)}

<style>
  /* On mobile, collapse the meta row to a single line — drop the "updated" verb,
     inline the icons, drop the "min read" suffix. Keeps the header from being a wall. */
  @media (max-width: 600px) {
    .article-meta { gap: var(--sp-2); font-size: var(--fs-xs); }
    .article-meta-updated span,
    .article-meta-time span { display: none; }
    .article-meta-updated::before { content: "↻ "; }
    .article-meta-time::after { content: " read"; }
  }
</style>
