---
import { getAllCategories, getAllTags, getAllEntries, COLLECTIONS, COLLECTION_LABELS } from '../utils/content';

interface Props {
  activeSlug?: string;
  activeCollection?: string;
}

const { activeSlug, activeCollection } = Astro.props;
const path = Astro.url.pathname;
const categories = await getAllCategories();
const tags = await getAllTags();

// Only show collections that have at least one entry — prevents dead-end links
// and keeps the sidebar honest.
const all = await getAllEntries();
const collectionsWithContent = COLLECTIONS.filter((c) =>
  all.some((e) => e.collection === c)
);
---

<nav class="sidebar-nav" aria-label="Knowledge base navigation">
  <h3>Browse</h3>
  <ul>
    <li><a href="/" class={path === '/' ? 'active' : ''}>Home</a></li>
    <li><a href="/articles" class={path === '/articles' ? 'active' : ''}>All articles</a></li>
    <li><a href="/timeline" class={path === '/timeline' ? 'active' : ''}>Timeline</a></li>
    <li><a href="/graph" class={path === '/graph' ? 'active' : ''}>Graph view</a></li>
    <li><a href="/archive" class={path === '/archive' ? 'active' : ''}>Archive</a></li>
    <li><a href="/az" class={path === '/az' ? 'active' : ''}>A–Z index</a></li>
    <li><a href="/random" class={path === '/random' ? 'active' : ''}>Random article</a></li>
  </ul>

  {COLLECTIONS.length > 0 && (
    <>
      <h3>Collections</h3>
      <ul>
        {COLLECTIONS.map((c) => (
          <li><a href={`/${c}`} class={activeCollection === c ? 'active' : ''}>{COLLECTION_LABELS[c]}</a></li>
        ))}
      </ul>
    </>
  )}

  {categories.length > 0 && (
    <details class="sidebar-categories" open>
      <summary>Categories ({categories.length})</summary>
      <ul>
        {categories.slice(0, 15).map(c => (
          <li><a href={`/category/${c.category}`}>{c.category} ({c.count})</a></li>
        ))}
      </ul>
    </details>
  )}

  {tags.length > 0 && (
    <details class="sidebar-categories">
      <summary>Tags ({tags.length})</summary>
      <ul>
        {tags.slice(0, 30).map(t => (
          <li><a href={`/tag/${t}`}>#{t}</a></li>
        ))}
      </ul>
    </details>
  )}
</nav>
