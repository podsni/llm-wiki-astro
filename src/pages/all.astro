---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllEntries, getEntryUrl, COLLECTIONS, COLLECTION_LABELS } from '../utils/content';
import { formatDate, daysAgo } from '../utils/format';
import type { CollectionEntry } from 'astro:content';

// Static SSG. Query params (?sort=, ?col=, ?tag=) are handled client-side:
// we pre-compute a JSON payload, render the default view (Newest), and a
// small inline script re-orders / filters the DOM based on window.location.search.

const fs = await import('node:fs/promises');
const path = await import('node:path');

const all = await getAllEntries();

// Resolve collection for a given entry id (slugs are unique per collection).
const allEntriesById = new Map<string, { collection: typeof COLLECTIONS[number]; entry: CollectionEntry<typeof COLLECTIONS[number]> }>();
for (const { collection, entry } of all) {
  allEntriesById.set(`${collection}/${entry.id}`, { collection, entry });
}

// Pre-compute file mtime for every entry so client-side sort is accurate.
const enriched: {
  id: string;
  collection: typeof COLLECTIONS[number];
  title: string;
  description: string;
  date: string;
  updated?: string;
  created?: string;
  fileMtime: number;
  fileBirthtime: number;
  url: string;
  tags: string[];
}[] = [];

for (const { collection, entry } of all) {
  const filePath = path.join(process.cwd(), 'src', 'content', collection, `${entry.id}.md`);
  let fileMtime = 0;
  let fileBirthtime = 0;
  try {
    const stat = await fs.stat(filePath);
    fileMtime = stat.mtimeMs;
    fileBirthtime = stat.birthtimeMs || stat.mtimeMs;
  } catch {}
  const f = entry.data as { created?: Date };
  enriched.push({
    id: `${collection}/${entry.id}`,
    collection,
    title: entry.data.title,
    description: entry.data.description ?? '',
    date: entry.data.date.toISOString(),
    updated: entry.data.updated?.toISOString(),
    created: f.created?.toISOString(),
    fileMtime,
    fileBirthtime,
    url: getEntryUrl(collection, entry.id),
    tags: entry.data.tags ?? [],
  });
}

// Pre-sort by created/mtime desc for default rendering.
const getCreated = (e: typeof enriched[number]): number => {
  if (e.created) return new Date(e.created).valueOf();
  if (e.updated) return new Date(e.updated).valueOf();
  return e.fileBirthtime || e.fileMtime || new Date(e.date).valueOf();
};
enriched.sort((a, b) => getCreated(b) - getCreated(a));

// Per-collection counts and all tags (for filter UI).
const colCounts = new Map<string, number>();
for (const e of enriched) colCounts.set(e.collection, (colCounts.get(e.collection) ?? 0) + 1);

const tagCounts = new Map<string, number>();
for (const e of enriched) for (const t of e.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const allTags = [...tagCounts.entries()]
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag));

const sortOptions = [
  { key: 'newest', label: 'Newest' },
  { key: 'updated', label: 'Recently updated' },
  { key: 'date', label: 'By date' },
  { key: 'title', label: 'A → Z' },
];

// JSON payload for client-side rendering. Embed inline so no extra fetch.
const payload = JSON.stringify({
  entries: enriched,
  collections: COLLECTIONS,
  labels: COLLECTION_LABELS,
  tags: allTags,
});
---

<BaseLayout title="All articles" description="Browse all articles, notes, concepts, projects, and more in the LLM Wiki.">
  <div class="container all-page">
    <header class="all-header">
      <h1>All articles</h1>
      <p class="all-subtitle" data-subtitle>
        {enriched.length} {enriched.length === 1 ? 'entry' : 'entries'}
      </p>
    </header>

    <section class="all-filters" aria-label="Filters">
      <div class="filter-row">
        <span class="filter-label">Collection</span>
        <div class="filter-chips" data-filter-group="col">
          <a class="chip chip-active" data-col="all" href="/all">
            All <span class="chip-count">{enriched.length}</span>
          </a>
          {COLLECTIONS.map((c) => (
            <a class="chip" data-col={c} href={`/all?col=${c}`}>
              {COLLECTION_LABELS[c]} <span class="chip-count">{colCounts.get(c) ?? 0}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="filter-row">
        <span class="filter-label">Sort</span>
        <div class="filter-chips" data-filter-group="sort">
          {sortOptions.map((o, i) => (
            <a class={`chip ${i === 0 ? 'chip-active' : ''}`} data-sort={o.key} href={`/all?sort=${o.key}`}>
              {o.label}
            </a>
          ))}
        </div>
      </div>

      {allTags.length > 0 && (
        <div class="filter-row">
          <span class="filter-label">Tag</span>
          <div class="filter-chips filter-chips-scroll" data-filter-group="tag">
            <a class="chip chip-small chip-active" data-tag="" href="/all">Any</a>
            {allTags.slice(0, 20).map((t) => (
              <a class="chip chip-small" data-tag={t.tag} href={`/all?tag=${encodeURIComponent(t.tag)}`}>
                #{t.tag} <span class="chip-count">{t.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </section>

    <div class="all-empty" data-empty hidden>
      <p>No entries match these filters.</p>
      <a class="chip" href="/all">Clear filters</a>
    </div>

    <div data-list-mount></div>
  </div>

  <script type="application/json" id="all-data" set:html={payload}></script>
</BaseLayout>

<script>
  type Entry = {
    id: string;
    collection: string;
    title: string;
    description: string;
    date: string;
    updated?: string;
    created?: string;
    fileMtime: number;
    fileBirthtime: number;
    url: string;
    tags: string[];
  };
  type Payload = {
    entries: Entry[];
    collections: readonly string[];
    labels: Record<string, string>;
    tags: { tag: string; count: number }[];
  };

  const data = JSON.parse(document.getElementById('all-data')?.textContent ?? '{}') as Payload;
  const mount = document.querySelector('[data-list-mount]') as HTMLElement;
  const subtitle = document.querySelector('[data-subtitle]') as HTMLElement;
  const emptyEl = document.querySelector('[data-empty]') as HTMLElement;

  if (!mount || !data.entries) {
    // Bail silently if data missing.
  } else {
    const getCreated = (e: Entry): number => {
      if (e.created) return new Date(e.created).valueOf();
      if (e.updated) return new Date(e.updated).valueOf();
      return e.fileBirthtime || e.fileMtime || new Date(e.date).valueOf();
    };

    const formatDateShort = (iso: string): string => {
      const d = new Date(iso);
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    };

    const ageLabel = (ts: number): string => {
      const days = Math.floor((Date.now() - ts) / 86400000);
      if (days < 0) return 'today';
      if (days === 0) return 'today';
      if (days === 1) return 'yesterday';
      if (days < 7) return `${days}d ago`;
      if (days < 30) return `${Math.floor(days / 7)}w ago`;
      if (days < 365) return `${Math.floor(days / 30)}mo ago`;
      return `${Math.floor(days / 365)}y ago`;
    };

    const esc = (s: string) =>
      String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

    const renderItem = (e: Entry, sort: string): string => {
      const createdTs = getCreated(e);
      const createdDate = new Date(createdTs);
      const ageDays = Math.floor((Date.now() - createdTs) / 86400000);
      const isFresh = ageDays <= 2;
      const label = data.labels[e.collection] ?? e.collection;
      const age = ageLabel(createdTs);
      const tagsHtml = (e.tags ?? [])
        .slice(0, 4)
        .map((t) => `<span class="meta-tag">#${esc(t)}</span>`)
        .join(' ');
      const meta =
        sort === 'newest'
          ? `<span class="meta-age" title="${esc(createdDate.toISOString())}">added ${esc(age)}</span>`
          : sort === 'updated' && e.updated
            ? `<span>updated ${esc(formatDateShort(e.updated))}</span>`
            : sort === 'date'
              ? `<span>${esc(formatDateShort(e.date))}</span>`
              : `<span>added ${esc(age)}</span>`;
      return `
        <a class="list-item" href="${esc(e.url)}">
          <div class="list-item-head">
            <span class="list-item-title">${esc(e.title)}</span>
            ${isFresh ? '<span class="badge badge-fresh">new</span>' : ''}
          </div>
          ${e.description ? `<span class="list-item-description">${esc(e.description)}</span>` : ''}
          <span class="list-item-meta">
            <span class="pill pill-${esc(e.collection)}">${esc(label)}</span>
            ${meta}
            ${tagsHtml ? `<span class="meta-tags">${tagsHtml}</span>` : ''}
          </span>
        </a>
      `;
    };

    const renderList = (entries: Entry[], sort: string): string => {
      // Group by month when sort is time-based; flat for title.
      if (sort === 'title') {
        return `<div class="all-list">${entries.map((e) => renderItem(e, sort)).join('')}</div>`;
      }
      const groupMap = new Map<string, { label: string; items: Entry[] }>();
      for (const e of entries) {
        let ts: Date;
        if (sort === 'date') ts = new Date(e.date);
        else if (sort === 'updated' && e.updated) ts = new Date(e.updated);
        else ts = new Date(getCreated(e));
        const key = `${ts.getFullYear()}-${String(ts.getMonth() + 1).padStart(2, '0')}`;
        const label = ts.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
        if (!groupMap.has(key)) groupMap.set(key, { label, items: [] });
        groupMap.get(key)!.items.push(e);
      }
      return [...groupMap.entries()]
        .map(
          ([, g]) =>
            `<section class="all-group"><h2 class="all-group-label">${esc(g.label)}</h2><div class="all-list">${g.items.map((e) => renderItem(e, sort)).join('')}</div></section>`,
        )
        .join('');
    };

    const applyState = () => {
      const params = new URLSearchParams(window.location.search);
      const sort = params.get('sort') ?? 'newest';
      const col = params.get('col') ?? 'all';
      const tag = params.get('tag') ?? '';

      // Update active chip states.
      document.querySelectorAll<HTMLElement>('[data-filter-group="sort"] .chip').forEach((chip) => {
        const isActive = (chip.dataset.sort ?? '') === sort;
        chip.classList.toggle('chip-active', isActive);
      });
      document.querySelectorAll<HTMLElement>('[data-filter-group="col"] .chip').forEach((chip) => {
        const isActive = (chip.dataset.col ?? 'all') === col;
        chip.classList.toggle('chip-active', isActive);
      });
      document.querySelectorAll<HTMLElement>('[data-filter-group="tag"] .chip').forEach((chip) => {
        const isActive = (chip.dataset.tag ?? '') === tag;
        chip.classList.toggle('chip-active', isActive);
      });

      // Filter entries.
      let filtered = data.entries;
      if (col !== 'all') filtered = filtered.filter((e) => e.collection === col);
      if (tag) filtered = filtered.filter((e) => e.tags.some((t) => t.toLowerCase() === tag.toLowerCase()));

      // Sort entries.
      if (sort === 'title') {
        filtered = [...filtered].sort((a, b) => a.title.localeCompare(b.title));
      } else if (sort === 'date') {
        filtered = [...filtered].sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
      } else if (sort === 'updated') {
        filtered = [...filtered].sort((a, b) => {
          const ad = a.updated ? new Date(a.updated).valueOf() : 0;
          const bd = b.updated ? new Date(b.updated).valueOf() : 0;
          if (bd !== ad) return bd - ad;
          return new Date(b.date).valueOf() - new Date(a.date).valueOf();
        });
      } else {
        // 'newest' (default): created/mtime desc
        filtered = [...filtered].sort((a, b) => getCreated(b) - getCreated(a));
      }

      // Render.
      if (filtered.length === 0) {
        mount.innerHTML = '';
        emptyEl.hidden = false;
      } else {
        emptyEl.hidden = true;
        mount.innerHTML = renderList(filtered, sort);
      }

      // Update subtitle.
      const colLabel = col === 'all' ? '' : ` in <strong>${esc(data.labels[col] ?? col)}</strong>`;
      const tagHtml = tag ? ` tagged <strong>#${esc(tag)}</strong>` : '';
      subtitle.innerHTML = `${filtered.length} of ${data.entries.length} ${data.entries.length === 1 ? 'entry' : 'entries'}${colLabel}${tagHtml}`;

      // Update page title.
      document.title = sort === 'newest' && col === 'all' && !tag
        ? 'All articles — LLM Wiki'
        : `All articles (${sort}) — LLM Wiki`;
    };

    // Intercept chip clicks so we update the URL with pushState and re-render
    // without a full page reload. Falls back to default link behavior if JS
    // is unavailable.
    document.querySelectorAll<HTMLAnchorElement>('.all-filters .chip').forEach((chip) => {
      chip.addEventListener('click', (ev) => {
        ev.preventDefault();
        const href = chip.getAttribute('href') ?? '/all';
        const u = new URL(href, window.location.origin);
        window.history.pushState({}, '', u.pathname + u.search);
        applyState();
        // Scroll to top of list so user sees the result.
        const listTop = document.querySelector('.all-filters');
        if (listTop) {
          const rect = listTop.getBoundingClientRect();
          window.scrollTo({ top: window.scrollY + rect.top - 12, behavior: 'smooth' });
        }
      });
    });

    window.addEventListener('popstate', applyState);

    // Initial render (handles direct deep-link to ?sort=foo etc.).
    applyState();
  }
</script>

<style is:global>
  .all-page {
    padding-top: var(--sp-6, 1.5rem);
    padding-bottom: var(--sp-8, 3rem);
  }
  .all-header {
    margin-bottom: var(--sp-5, 1.25rem);
  }
  .all-header h1 {
    margin: 0 0 var(--sp-2, 0.5rem);
    font-family: var(--font-display, serif);
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    line-height: 1.1;
  }
  .all-subtitle {
    margin: 0;
    color: var(--color-text-soft, #666);
    font-size: 0.95rem;
  }

  .all-filters {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3, 0.75rem);
    margin-bottom: var(--sp-6, 1.5rem);
    padding: var(--sp-4, 1rem);
    background: var(--color-bg-soft, #f7f7f5);
    border: 1px solid var(--color-border, #e5e5e0);
    border-radius: 8px;
  }
  .filter-row {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3, 0.75rem);
    flex-wrap: wrap;
  }
  .filter-label {
    flex-shrink: 0;
    width: 88px;
    padding-top: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-soft, #666);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    flex: 1;
  }
  .filter-chips-scroll {
    overflow-x: auto;
    flex-wrap: nowrap;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    padding-bottom: 4px;
  }
  .filter-chips-scroll .chip {
    flex-shrink: 0;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    font-size: 0.875rem;
    line-height: 1.3;
    color: var(--color-text, #1a1a1a);
    background: var(--color-bg, #fff);
    border: 1px solid var(--color-border, #d4d4cf);
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 120ms, border-color 120ms, color 120ms;
    cursor: pointer;
  }
  .chip:hover {
    background: var(--color-bg-hover, #f0f0eb);
    border-color: var(--color-text-soft, #999);
  }
  .chip-active {
    background: var(--color-primary, #2d4a3a);
    color: var(--color-bg, #fff);
    border-color: var(--color-primary, #2d4a3a);
  }
  .chip-active:hover {
    background: var(--color-primary-dark, #1f3328);
    border-color: var(--color-primary-dark, #1f3328);
    color: var(--color-bg, #fff);
  }
  .chip-small {
    padding: 4px 10px;
    font-size: 0.8rem;
  }
  .chip-count {
    display: inline-block;
    padding: 1px 6px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-soft, #666);
    background: var(--color-bg-soft, #f7f7f5);
    border-radius: 999px;
    line-height: 1.4;
  }
  .chip-active .chip-count {
    background: rgba(255, 255, 255, 0.2);
    color: var(--color-bg, #fff);
  }

  .all-group {
    margin-bottom: var(--sp-6, 1.5rem);
  }
  .all-group-label {
    margin: 0 0 var(--sp-3, 0.75rem);
    padding-bottom: var(--sp-2, 0.5rem);
    font-family: var(--font-display, serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text-soft, #666);
    border-bottom: 1px solid var(--color-border, #e5e5e0);
  }

  .all-list {
    display: flex;
    flex-direction: column;
  }
  .all-list .list-item {
    padding: var(--sp-3, 0.75rem) var(--sp-2, 0.5rem);
    border-bottom: 1px solid var(--color-border-soft, #f0f0eb);
  }

  .list-item-head {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .badge {
    display: inline-block;
    padding: 1px 7px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 3px;
  }
  .badge-fresh {
    background: #2d6a4f;
    color: white;
  }

  .pill {
    display: inline-block;
    padding: 1px 8px;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: 999px;
    background: var(--color-bg-soft, #f7f7f5);
    color: var(--color-text-soft, #555);
  }
  .pill-notes { background: #fef3c7; color: #78350f; }
  .pill-articles { background: #dbeafe; color: #1e3a8a; }
  .pill-concepts { background: #e9d5ff; color: #581c87; }
  .pill-people { background: #fce7f3; color: #831843; }
  .pill-projects { background: #d1fae5; color: #064e3b; }
  .pill-books { background: #fed7aa; color: #7c2d12; }
  .pill-research { background: #cffafe; color: #155e75; }
  .pill-timeline { background: #e0e7ff; color: #312e81; }
  .pill-sources { background: #f3e8ff; color: #581c87; }

  .meta-age {
    color: var(--color-primary, #2d4a3a);
    font-weight: 500;
  }
  .meta-tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px;
    color: var(--color-text-soft, #888);
  }
  .meta-tag {
    font-size: 0.78rem;
  }

  .all-empty {
    text-align: center;
    padding: var(--sp-8, 3rem) var(--sp-4, 1rem);
    color: var(--color-text-soft, #666);
  }
  .all-empty p {
    margin: 0 0 var(--sp-4, 1rem);
  }

  @media (max-width: 640px) {
    .filter-row {
      flex-direction: column;
      gap: var(--sp-2, 0.5rem);
    }
    .filter-label {
      width: auto;
      padding-top: 0;
    }
    .filter-chips {
      width: 100%;
    }
    .all-list .list-item {
      padding: var(--sp-3, 0.75rem) 0;
    }
  }
</style>
