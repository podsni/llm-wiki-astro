---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntriesByCollection, getEntryUrl, COLLECTIONS, COLLECTION_LABELS, COLLECTION_DESCRIPTIONS, getAllTagsForCollection, getAllCategoriesForCollection } from '../../utils/content';
import { formatDate } from '../../utils/format';

export async function getStaticPaths() {
  return COLLECTIONS.map((collection) => ({ params: { collection } }));
}

const { collection } = Astro.params;
if (!collection || !COLLECTIONS.includes(collection as any)) {
  return Astro.redirect('/404');
}

const all = await getEntriesByCollection(collection as any);
const label = COLLECTION_LABELS[collection as keyof typeof COLLECTION_LABELS];
const description = COLLECTION_DESCRIPTIONS[collection as keyof typeof COLLECTION_DESCRIPTIONS] || `All ${label.toLowerCase()} in the wiki.`;

all.sort((a, b) => new Date(b.data.updated ?? b.data.date).valueOf() - new Date(a.data.updated ?? a.data.date).valueOf());

const tags = await getAllTagsForCollection(collection as any);
const categories = await getAllCategoriesForCollection(collection as any);
---

<BaseLayout title={label} description={description}>
  <div class="container">
    <header class="article-header" style="margin-top: var(--sp-6);">
      <span class="category-chip">{label}</span>
      <h1 style="margin-top: 0;">{label}</h1>
      <p class="article-description">{description}</p>

      <div class="tag-list" style="margin-top: var(--sp-4);">
        <a class="tag" href="/articles" style="background: var(--color-bg-soft);">All collections</a>
        {COLLECTIONS.map((c) => (
          <a class="tag" href={`/${c}`} style={c === collection ? 'background: var(--color-primary); color: var(--color-bg);' : ''}>
            {COLLECTION_LABELS[c]}
          </a>
        ))}
      </div>

      {all.length > 0 && (
        <div class="article-meta" style="margin-top: var(--sp-4); font-size: var(--fs-sm); color: var(--color-text-soft);">
          <span>{all.length} {all.length === 1 ? 'entry' : 'entries'}</span>
          {tags.length > 0 && <span>· {tags.length} tag{tags.length === 1 ? '' : 's'}</span>}
          {categories.length > 0 && <span>· {categories.length} categor{categories.length === 1 ? 'y' : 'ies'}</span>}
        </div>
      )}
    </header>

    {all.length === 0 ? (
      <div class="empty-state" style="text-align: center; padding: var(--sp-7) var(--sp-4); color: var(--color-text-soft);">
        <p style="font-size: 1.1rem; margin-bottom: var(--sp-3);">No {label.toLowerCase()} yet.</p>
        <p style="font-size: var(--fs-sm);">This collection is part of the wiki structure but doesn't have any entries yet.</p>
      </div>
    ) : (
      <div>
        {all.map((entry) => (
          <a class="list-item" href={getEntryUrl(collection as any, entry.id)}>
            <span class="list-item-title">{entry.data.title}</span>
            {entry.data.description && <span class="list-item-description">{entry.data.description}</span>}
            <span class="list-item-meta">
              {formatDate(entry.data.date)}
              {entry.data.updated && entry.data.updated.valueOf() !== entry.data.date.valueOf() && (
                <> · updated {formatDate(entry.data.updated)}</>
              )}
              {entry.data.tags && entry.data.tags.length > 0 && (
                <> · {entry.data.tags.slice(0, 3).map((t: string) => `#${t}`).join(' ')}</>
              )}
            </span>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
