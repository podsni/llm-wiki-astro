---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllEntries, getRecentEntries, getAllCategories, getAllTags, getEntryUrl } from '../utils/content';
import { formatDate } from '../utils/format';

const recent = await getRecentEntries(6);
const featured = recent.slice(0, 3);
const newNotes = recent.slice(3);
const categories = await getAllCategories();
const tags = await getAllTags();
const all = await getAllEntries();

// Popular: most-connected entries (by inbound related count) — simple heuristic
const inboundCount = new Map<string, number>();
for (const { collection: sc, entry: se } of all) {
  for (const rel of se.data.related ?? []) {
    const [c, s] = rel.includes('/') ? rel.split('/') : [null, rel];
    const found = all.find(({ collection, entry }) => (c ? collection === c : true) && entry.id === s);
    if (found) {
      const key = `${found.collection}/${found.entry.id}`;
      inboundCount.set(key, (inboundCount.get(key) ?? 0) + 1);
    }
  }
}
const popular = [...inboundCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([key]) => all.find(({ collection, entry }) => `${collection}/${entry.id}` === key))
  .filter(Boolean);

// Featured articles (marked with quality: featured) — top priority
const featuredByQuality = all.filter(({ entry }) => entry.data.quality === 'featured').slice(0, 3);
const heroArticles = featuredByQuality.length > 0 ? featuredByQuality : featured;

// Find a real article that links to "the wiki" as a portal quote
const portalArticle = all.find(({ collection, entry }) => entry.id === 'large-language-model') ?? heroArticles[0];
---

<BaseLayout title="LLM Wiki" description="A personal knowledge base — articles, concepts, research, and digital gardening.">
  <div class="container">
    <section class="hero">
      <h1>LLM Wiki</h1>
      <p class="text-soft" style="font-style: italic; font-family: var(--font-serif); font-size: var(--fs-md); color: var(--color-text-muted); max-width: 500px; margin: 0 auto var(--sp-5); letter-spacing: 0.04em;">
        ~ a personal compendium ~
      </p>
      <p>A personal knowledge base — articles, concepts, research, projects, books, and the connections between them. A digital garden, growing.</p>
      <button class="hero-search" data-search-open type="button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
        Search the wiki...
        <kbd style="margin-left: auto;">⌘K</kbd>
      </button>
      <div class="hero-actions" style="margin-top: var(--sp-4); display: flex; gap: var(--sp-3); justify-content: center; flex-wrap: wrap;">
        <a class="hero-btn" href="/articles">Browse all</a>
        <a class="hero-btn hero-btn-secondary" href="/az">A–Z index</a>
        <a class="hero-btn hero-btn-secondary" href="/graph">Graph view</a>
        <a class="hero-btn hero-btn-secondary" href="/random">Random article</a>
      </div>
    </section>

    <section class="home-section portal-stats">
      <div class="portal-stat">
        <strong>{all.length}</strong>
        <span>articles</span>
      </div>
      <div class="portal-stat">
        <strong>{categories.length}</strong>
        <span>categories</span>
      </div>
      <div class="portal-stat">
        <strong>{tags.length}</strong>
        <span>tags</span>
      </div>
      <div class="portal-stat">
        <strong>9</strong>
        <span>collections</span>
      </div>
    </section>

    {heroArticles.length > 0 && (
      <section class="home-section">
        <div class="home-section-header">
          <h2>Featured</h2>
          <a href="/articles" class="home-section-link">All articles →</a>
        </div>
        <div class="card-grid">
          {heroArticles.map(({ collection, entry }) => (
            <a class="card" href={getEntryUrl(collection, entry.id)}>
              {entry.data.quality === 'featured' && <span class="card-badge">★ Featured</span>}
              <h3 class="card-title">{entry.data.title}</h3>
              {entry.data.description && <p class="card-description">{entry.data.description}</p>}
              <div class="card-meta">
                <span>{collection}</span>
                <span>·</span>
                <span>{formatDate(entry.data.date)}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {newNotes.length > 0 && (
      <section class="home-section">
        <div class="home-section-header">
          <h2>Recent updates</h2>
          <a href="/recent" class="home-section-link">What's new →</a>
        </div>
        <div>
          {newNotes.map(({ collection, entry }) => (
            <a class="list-item" href={getEntryUrl(collection, entry.id)}>
              <span class="list-item-title">{entry.data.title}</span>
              {entry.data.description && <span class="list-item-description">{entry.data.description}</span>}
              <span class="list-item-meta">
                {collection} · updated {formatDate(entry.data.updated ?? entry.data.date)}
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    {categories.length > 0 && (
      <section class="home-section">
        <div class="home-section-header">
          <h2>Browse by category</h2>
          <a href="/articles" class="home-section-link">All categories →</a>
        </div>
        <div class="tag-list">
          {categories.map(c => (
            <a class="tag" href={`/category/${c.category}`}>{c.category} ({c.count})</a>
          ))}
        </div>
      </section>
    )}

    {popular.length > 0 && (
      <section class="home-section">
        <div class="home-section-header">
          <h2>Popular</h2>
        </div>
        <div class="card-grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
          {popular.map((p) => p && (
            <a class="card" href={getEntryUrl(p.collection, p.entry.id)}>
              <h3 class="card-title">{p.entry.data.title}</h3>
              {p.entry.data.description && <p class="card-description">{p.entry.data.description}</p>}
              <div class="card-meta">
                <span>{p.collection}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {tags.length > 0 && (
      <section class="home-section">
        <div class="home-section-header">
          <h2>Tags</h2>
          <div>
            <a href="/articles" class="home-section-link">All articles →</a>
          </div>
        </div>
        <div class="tag-list">
          {tags.map(t => <a class="tag" href={`/tag/${t.tag}`}>#{t.tag} ({t.count})</a>)}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .hero-actions { margin-top: var(--sp-4); }
  .hero-btn {
    display: inline-block;
    padding: var(--sp-2) var(--sp-4);
    background: var(--color-primary);
    color: var(--color-bg);
    border-radius: var(--radius);
    font-size: var(--fs-sm);
    font-weight: 600;
    border: 1px solid var(--color-primary);
  }
  .hero-btn:hover { background: var(--color-primary-soft); color: var(--color-bg); border-color: var(--color-primary-soft); }
  .hero-btn-secondary { background: transparent; color: var(--color-primary); }
  .hero-btn-secondary:hover { background: var(--color-primary-bg); color: var(--color-primary); }

  .portal-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--sp-4);
    padding: var(--sp-5) 0;
    border-top: 1px solid var(--color-border-soft);
    border-bottom: 1px solid var(--color-border-soft);
    text-align: center;
  }
  .portal-stat strong {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--fs-3xl);
    color: var(--color-primary);
    font-weight: 700;
  }
  .portal-stat span {
    display: block;
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: var(--sp-1);
  }

  .card-badge {
    display: inline-block;
    font-size: var(--fs-xs);
    background: #fdf3d1;
    color: #7a5a16;
    border: 1px solid #e8c97a;
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
    margin-bottom: var(--sp-2);
    font-weight: 600;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  :root[data-theme='dark'] .card-badge { background: #3a2f10; color: #e8c97a; border-color: #7a5a16; }
</style>
