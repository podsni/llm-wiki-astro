---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllEntries, getRecentEntries, getAllCategories, getAllTags, getEntryUrl } from '../utils/content';
import { formatDate } from '../utils/format';

const recent = await getRecentEntries(6);
const all = await getAllEntries();
const categories = await getAllCategories();
const tags = await getAllTags();

// Featured = articles explicitly marked quality:featured
const featured = all.filter(({ entry }) => entry.data.quality === 'featured').slice(0, 3);

// Latest 3 non-featured updates for the secondary row
const updates = recent.filter(({ entry }) => entry.data.quality !== 'featured').slice(0, 4);

// Popular: most-connected articles (heuristic on inbound related)
const inboundCount = new Map<string, number>();
for (const { collection: sc, entry: se } of all) {
  for (const rel of se.data.related ?? []) {
    const [c, s] = rel.includes('/') ? rel.split('/') : [null, rel];
    const found = all.find(({ collection, entry }) => (c ? collection === c : true) && entry.id === s);
    if (found) {
      const key = `${found.collection}/${found.entry.id}`;
      inboundCount.set(key, (inboundCount.get(key) ?? 0) + 1);
    }
  }
}
const popular = [...inboundCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([key]) => all.find(({ collection, entry }) => `${collection}/${entry.id}` === key))
  .filter(Boolean);
---

<BaseLayout title="LLM Wiki" description="A personal knowledge base — articles, concepts, research, and digital gardening.">
  <div class="container">

    <!-- HERO: asymmetric, single idea, no SaaS button-row -->
    <section class="hero" aria-labelledby="hero-title">
      <p class="hero-eyebrow">A digital garden in progress</p>
      <h1 id="hero-title">A small <em>compendium</em> of things worth knowing.</h1>
      <p class="hero-lede">Articles, concepts, research notes, and the quiet connections between them — written and tended over time. Built as a personal wiki, kept as a reference book.</p>
      <button class="hero-search" data-search-open type="button" aria-label="Open search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
        <span>Search {all.length} articles, {tags.length} tags…</span>
        <kbd>⌘ K</kbd>
      </button>
    </section>

    {featured.length > 0 && (
      <section class="home-section" aria-labelledby="featured-title">
        <div class="home-section-header">
          <h2 id="featured-title">Featured</h2>
          <a href="/articles" class="home-section-link">All articles →</a>
        </div>
        <div class="featured-list">
          {featured.map(({ collection, entry }, i) => (
            <a class="featured-item" href={getEntryUrl(collection, entry.id)}>
              <span class="featured-index">{String(i + 1).padStart(2, '0')}</span>
              <span class="featured-body">
                <span class="featured-title">{entry.data.title}</span>
                {entry.data.description && <span class="featured-description">{entry.data.description}</span>}
                <span class="featured-meta">
                  {collection} · {formatDate(entry.data.updated ?? entry.data.date)}
                </span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    {updates.length > 0 && (
      <section class="home-section" aria-labelledby="recent-title">
        <div class="home-section-header">
          <h2 id="recent-title">Recent</h2>
          <a href="/recent" class="home-section-link">All changes →</a>
        </div>
        <div class="featured-list">
          {updates.map(({ collection, entry }, i) => (
            <a class="featured-item" href={getEntryUrl(collection, entry.id)}>
              <span class="featured-index">{String(i + 1).padStart(2, '0')}</span>
              <span class="featured-body">
                <span class="featured-title">{entry.data.title}</span>
                {entry.data.description && <span class="featured-description">{entry.data.description}</span>}
                <span class="featured-meta">
                  {collection} · {formatDate(entry.data.updated ?? entry.data.date)}
                </span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    {popular.length > 0 && (
      <section class="home-section" aria-labelledby="popular-title">
        <div class="home-section-header">
          <h2 id="popular-title">Most connected</h2>
          <a href="/graph" class="home-section-link">View graph →</a>
        </div>
        <div class="featured-list">
          {popular.map((p, i) => p && (
            <a class="featured-item" href={getEntryUrl(p.collection, p.entry.id)}>
              <span class="featured-index">{String(i + 1).padStart(2, '0')}</span>
              <span class="featured-body">
                <span class="featured-title">{p.entry.data.title}</span>
                {p.entry.data.description && <span class="featured-description">{p.entry.data.description}</span>}
                <span class="featured-meta">
                  {p.collection} · {inboundCount.get(`${p.collection}/${p.entry.id}`) ?? 0} inbound links
                </span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    {categories.length > 0 && (
      <section class="home-section" aria-labelledby="cats-title">
        <div class="home-section-header">
          <h2 id="cats-title">Browse by category</h2>
        </div>
        <div class="tag-list">
          {categories.map(c => (
            <a class="tag" href={`/category/${c.category}`}>{c.category} <span class="tag-count">{c.count}</span></a>
          ))}
        </div>
      </section>
    )}

    {tags.length > 0 && (
      <section class="home-section" aria-labelledby="tags-title">
        <div class="home-section-header">
          <h2 id="tags-title">Tags</h2>
          <a href="/articles" class="home-section-link">Browse all →</a>
        </div>
        <div class="tag-list tag-list-cloud">
          {tags.map(t => <a class="tag" href={`/tag/${t.tag}`}>#{t.tag} <span class="tag-count">{t.count}</span></a>)}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  /* Asymmetric featured list — no card grid, just editorial rows. */
  .featured-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }
  .featured-item {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--sp-4);
    padding: var(--sp-5) 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    text-decoration: none;
    align-items: baseline;
    transition: background var(--transition);
  }
  .featured-item:hover {
    background: var(--color-bg-soft);
    color: var(--color-text);
  }
  .featured-item:hover .featured-title { color: var(--color-primary); }
  .featured-index {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
  .featured-body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .featured-title {
    font-family: var(--font-serif);
    font-size: var(--fs-xl);
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .featured-description {
    font-size: var(--fs-base);
    color: var(--color-text-soft);
    line-height: 1.5;
  }
  .featured-meta {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    text-transform: none;
    letter-spacing: 0.01em;
    margin-top: var(--sp-1);
    font-variant-numeric: tabular-nums;
  }

  .tag-count {
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
    margin-left: 0.3em;
    font-size: 0.85em;
  }
  .tag-list-cloud .tag {
    font-weight: 400;
  }
</style>
