---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllEntries, getEntryUrl, getAllCategories } from '../../utils/content';
import { formatDate } from '../../utils/format';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  return categories.map((c) => ({
    params: { slug: c.category },
    props: { category: c.category, count: c.count },
  }));
}

const { category, count } = Astro.props;
const all = await getAllEntries();
const items = all.filter(({ entry }) => entry.data.category === category).sort((a, b) =>
  new Date(b.entry.data.updated ?? b.entry.data.date).valueOf() - new Date(a.entry.data.updated ?? a.entry.data.date).valueOf()
);
---

<BaseLayout title={`Category: ${category}`} description={`Articles in the "${category}" category.`}>
  <div class="container-narrow">
    <header class="article-header" style="margin-top: var(--sp-6);">
      <span class="category-chip">Category</span>
      <h1 style="margin-top: 0;">{category}</h1>
      <p class="article-description">{count} article{count === 1 ? '' : 's'} in this category.</p>
    </header>

    {items.length === 0 ? (
      <p class="text-soft">No articles yet.</p>
    ) : (
      <div>
        {items.map(({ collection, entry }) => (
          <a class="list-item" href={getEntryUrl(collection, entry.id)}>
            <span class="list-item-title">{entry.data.title}</span>
            {entry.data.description && <span class="list-item-description">{entry.data.description}</span>}
            <span class="list-item-meta">
              {collection} · {formatDate(entry.data.updated ?? entry.data.date)}
            </span>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
