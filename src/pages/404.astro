---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="The page you were looking for has wandered off into the wider world.">
  <div class="container container-narrow not-found">
    <p class="not-found-eyebrow">Error 404</p>
    <h1 class="not-found-title">A page that is not, and was not, and is not to be.</h1>
    <p class="not-found-lede">
      The article you sought has slipped out of the index, or perhaps was never written at all.
      The wiki is tended by hand, and not every path leads somewhere — yet.
    </p>

    <div class="not-found-cta">
      <a class="hero-btn" href="/">Return home</a>
      <a class="hero-btn hero-btn-secondary" href="/az">Browse A–Z</a>
      <a class="hero-btn hero-btn-secondary" href="/random">Try a random page</a>
    </div>

    <p class="not-found-tip">
      Press <kbd>⌘</kbd> <kbd>K</kbd> to search, or browse the A–Z index for anything in the garden.
    </p>
  </div>
</BaseLayout>

<style>
  .not-found {
    padding: var(--sp-11) var(--sp-5);
    text-align: left;
  }
  .not-found-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 var(--sp-4);
  }
  .not-found-title {
    font-size: var(--fs-4xl);
    line-height: 1.1;
    margin: 0 0 var(--sp-5);
    max-width: 22ch;
    letter-spacing: -0.02em;
  }
  .not-found-lede {
    font-size: var(--fs-lg);
    color: var(--color-text-soft);
    margin: 0 0 var(--sp-7);
    max-width: 48ch;
    line-height: 1.5;
  }
  .not-found-cta {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    margin-bottom: var(--sp-7);
  }
  .not-found-tip {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }
  .not-found-tip kbd {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.1em 0.4em;
    margin: 0 0.1em;
  }
</style>
