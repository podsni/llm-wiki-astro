---
import { getAllEntries, getEntryUrl } from '../utils/content';

// Static list of all article URLs, sorted for stable diffs across builds.
// The actual random pick happens client-side at click time (see <script> below),
// so each click is a real random — not a build-time frozen redirect.
const all = await getAllEntries();
const urls = all.map((e) => getEntryUrl(e.collection, e.entry.id)).sort();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Pick a random article — LLM Wiki</title>
    <link rel="canonical" href="/random/" />
    <style>
      body {
        font-family: var(--font-serif);
        max-width: 480px;
        margin: 12vh auto;
        padding: 0 1.5rem;
        text-align: center;
        color: var(--color-text);
      }
      h1 { font-size: 1.75rem; margin: 0 0 0.5rem; }
      p { color: var(--color-text-soft); line-height: 1.6; margin: 0 0 2rem; }
      button {
        font: inherit;
        font-family: var(--font-sans);
        font-size: 1rem;
        padding: 0.85rem 1.75rem;
        background: var(--color-primary);
        color: var(--color-bg);
        border: none;
        border-radius: 4px;
        cursor: pointer;
        min-height: 48px;
        min-width: 200px;
      }
      button:hover { background: var(--color-primary-strong, var(--color-primary)); }
      button:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 3px;
      }
      #count { color: var(--color-text-muted); font-size: 0.85rem; margin-top: 2rem; }
    </style>
  </head>
  <body>
    <h1>Pick a random article</h1>
    <p>Every click is a fresh pick from the {urls.length} articles in the wiki.</p>
    <button type="button" id="pick">Open random article</button>
    <div id="count">&nbsp;</div>

    <script type="application/json" id="article-urls" set:html={JSON.stringify(urls)}></script>
    <script is:inline>
      (() => {
        const el = document.getElementById('article-urls');
        let urls = [];
        try { urls = JSON.parse(el.textContent || '[]'); } catch (_) { urls = []; }
        const btn = document.getElementById('pick');
        const count = document.getElementById('count');
        count.textContent = urls.length + ' articles to choose from';

        function pick() {
          if (!urls.length) return;
          const i = Math.floor(Math.random() * urls.length);
          location.href = urls[i];
        }
        btn.addEventListener('click', pick);
        // Optional: also support ?go=1 for instant redirect
        if (new URLSearchParams(location.search).get('go') === '1') pick();
      })();
    </script>
  </body>
</html>
