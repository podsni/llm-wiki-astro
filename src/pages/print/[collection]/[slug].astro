---
/**
 * Print-friendly view of an article. Renders the article with no nav, sidebar,
 * or other chrome. Linked from the "Print" button on each article.
 */
import { render } from 'astro:content';
import { getAllEntries, findEntry, getEntryUrl, COLLECTIONS, type CollectionName } from '~/utils/content';
import { formatDate, readingTime } from '~/utils/format';

export async function getStaticPaths() {
  const all = await getAllEntries();
  return all.map(({ collection, entry }) => ({
    params: { collection, slug: entry.id },
    props: { collection, slug: entry.id },
  }));
}

const { collection, slug } = Astro.props as { collection: string; slug: string };

if (!collection || !slug || !COLLECTIONS.includes(collection as CollectionName)) {
  return new Response('Not found', { status: 404 });
}

const entry = await findEntry(collection as CollectionName, slug);
if (!entry) return new Response('Not found', { status: 404 });

const { Content } = await render(entry);
const bodyText = entry.body || '';
const minutes = readingTime(bodyText);
const dateStr = formatDate(entry.data.date);
const updatedStr = entry.data.updated ? formatDate(entry.data.updated) : null;
const all = await getAllEntries();
const allByKey = new Map(all.map(e => [`${e.collection}/${e.entry.id}`, e]));
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{entry.data.title} — Print view</title>
  <style>
    @page { margin: 0.75in; }
    body { font-family: Georgia, 'Times New Roman', serif; font-size: 11pt; line-height: 1.5; color: #000; max-width: 7.5in; margin: 0 auto; padding: 1in 0.5in; }
    h1 { font-size: 24pt; margin: 0 0 0.2em; }
    h2 { font-size: 16pt; margin-top: 1.5em; border-bottom: 1px solid #ccc; padding-bottom: 0.2em; page-break-after: avoid; }
    h3 { font-size: 13pt; margin-top: 1em; page-break-after: avoid; }
    p { margin: 0 0 0.8em; }
    a { color: #000; text-decoration: underline; }
    a[href^="http"]::after { content: ' (' attr(href) ')'; font-size: 0.85em; color: #555; word-break: break-all; }
    .print-meta { font-size: 9pt; color: #555; border-top: 1px solid #ccc; border-bottom: 1px solid #ccc; padding: 0.4em 0; margin: 1em 0; }
    .print-meta span { margin-right: 1em; }
    blockquote { margin: 1em 0; padding: 0.3em 1em; border-left: 3px solid #888; font-style: italic; color: #333; }
    code { font-family: 'Courier New', monospace; font-size: 0.9em; background: #f4f4f4; padding: 0.1em 0.3em; }
    pre { background: #f4f4f4; padding: 0.5em; border: 1px solid #ddd; overflow-x: auto; font-size: 9pt; page-break-inside: avoid; }
    .print-footer { margin-top: 2em; padding-top: 0.5em; border-top: 1px solid #ccc; font-size: 9pt; color: #555; text-align: center; }
    figure, .infobox { page-break-inside: avoid; }
  </style>
</head>
<body>
  <header>
    <h1>{entry.data.title}</h1>
    {entry.data.description && <p style="font-size: 12pt; color: #444; font-style: italic;">{entry.data.description}</p>}
    <div class="print-meta">
      <span><strong>From:</strong> LLM Wiki</span>
      <span><strong>URL:</strong> llm-wiki.pages.dev{getEntryUrl(collection as CollectionName, entry.id)}</span>
      <span><strong>Created:</strong> {dateStr}</span>
      {updatedStr && <span><strong>Updated:</strong> {updatedStr}</span>}
      <span><strong>Read time:</strong> {minutes} min</span>
    </div>
  </header>

  <Content />

  <div class="print-footer">
    LLM Wiki — a personal knowledge base. CC BY-SA 4.0.
  </div>

  <script>
    // Auto-trigger print dialog on load
    window.addEventListener('load', () => {
      setTimeout(() => window.print(), 500);
    });
  </script>
</body>
</html>
