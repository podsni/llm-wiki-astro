        if (n.y < minY) minY = n.y;
        if (n.x > maxX) maxX = n.x;
        if (n.y > maxY) maxY = n.y;
      }
      // More padding on top (for search bar at top of canvas), small at bottom (zoom controls are small)
      var padTop = 80, padBottom = 20, padX = 50;
      var bboxW = maxX - minX + padX * 2;
      var bboxH = maxY - minY + padTop + padBottom;
      scale = Math.min(viewWidth / bboxW, viewHeight / bboxH, 1.5);
      viewX = minX - padX;
      viewY = minY - padTop;
    }

    // === Fullscreen (native Fullscreen API + custom fallback) ===
    var fsBtn = document.getElementById('fullscreen-btn');
    function enterFullscreen() {
      var el = document.documentElement;
      var req = el.requestFullscreen || el.webkitRequestFullscreen || el.mozRequestFullScreen || el.msRequestFullscreen;
      if (req) {
        try {
          var result = req.call(el);
          if (result && result.then) result.then(function() { onFullscreenChange(); }).catch(function() { fallbackCustom(); });
          else fallbackCustom();
        } catch (er) { fallbackCustom(); }
      } else {
        fallbackCustom();
      }
    }
    function exitFullscreen() {
      var exit = document.exitFullscreen || document.webkitExitFullscreen || document.mozCancelFullScreen || document.msExitFullscreen;
      if (exit && (document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement)) {
        try { exit.call(document); } catch (er) { fallbackCustom(false); }
      } else {
        fallbackCustom(false);
      }
    }
    function fallbackCustom(enter) {
      if (enter === undefined) enter = !container.classList.contains('is-fullscreen');
      if (enter) container.classList.add('is-fullscreen');
      else container.classList.remove('is-fullscreen');
      // Re-fit after CSS settles
      setTimeout(function() { resize(); fitToView(); requestRender(); }, 80);
    }
    function isFullscreenActive() {
      return !!(document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement || container.classList.contains('is-fullscreen'));
    }
    function onFullscreenChange() {
      // Sync class state with actual fullscreen state
      var isFs = !!(document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement);
      if (isFs) container.classList.add('is-fullscreen');
      else container.classList.remove('is-fullscreen');
      // Re-measure canvas (in native fullscreen, viewport size changes)
      setTimeout(function() {
        resize();
        // Keep visual position: re-fit so graph is centered
        if (isFs) fitToView();
        requestRender();
        showZoomLevel();
      }, 100);
    }
    document.addEventListener('fullscreenchange', onFullscreenChange);
    document.addEventListener('webkitfullscreenchange', onFullscreenChange);
    document.addEventListener('mozfullscreenchange', onFullscreenChange);
    document.addEventListener('MSFullscreenChange', onFullscreenChange);
    if (fsBtn) fsBtn.addEventListener('click', function() {
      if (isFullscreenActive()) exitFullscreen();
      else enterFullscreen();
      var hint = document.getElementById('graph-hint');
      if (hint) hint.classList.add('hidden');
    });

    // === Layout switcher (re-positions nodes, then re-renders) ===
    var layoutBtns = document.querySelectorAll('.layout-btn');
    function applyLayout(layout) {
      if (layout === 'cluster') {
        // Use server-computed positions
        for (var i = 0; i < nodes.length; i++) {
          nodes[i].x = nodes[i].x; // keep (already computed)
          nodes[i].y = nodes[i].y;
        }
        fitToView();
      } else if (layout === 'radial') {
        var sorted = nodes.slice().sort(function(a, b) { return b.degree - a.degree; });
        var cx = 600, cy = 350;
        for (var ri = 0; ri < sorted.length; ri++) {
          var n2 = sorted[ri];
          var t = ri / sorted.length;
          var rr = 50 + t * 280;
          var ang = ri * 0.5;
          n2.x = cx + Math.cos(ang) * rr;
          n2.y = cy + Math.sin(ang) * rr;
        }
        fitToView();
      } else if (layout === 'force') {
        // Simple force: keep current positions, just give a small shake
        for (var fi = 0; fi < nodes.length; fi++) {
          nodes[fi].x += (Math.random() - 0.5) * 20;
          nodes[fi].y += (Math.random() - 0.5) * 20;
        }
        fitToView();
      }
      requestRender();
    }
    layoutBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        layoutBtns.forEach(function(b) { b.classList.remove('is-active'); });
        btn.classList.add('is-active');
        applyLayout(btn.getAttribute('data-layout'));
      });
    });

    // === Filter chips ===
    var chips = document.querySelectorAll('.chip');
    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        chips.forEach(function(c) { c.classList.remove('is-active'); c.setAttribute('aria-pressed', 'false'); });
        chip.classList.add('is-active');
        chip.setAttribute('aria-pressed', 'true');
        filterCol = chip.getAttribute('data-filter') || '';
        requestRender();
      });
    });

    // === Search ===
    var search = document.getElementById('graph-search');
    var results = document.getElementById('search-results');
    var currentFocus = -1;

    function applySearchHighlight(ids) {
      if (!ids) {
        searchMatchIds = null;
      } else {
        searchMatchIds = ids;
      }
      requestRender();
    }

    function showResults(q) {
      q = (q || '').toLowerCase().trim();
      if (!q) {
        results.hidden = true;
        applySearchHighlight(null);
        return;
      }
      var matches = [];
      for (var i = 0; i < nodes.length; i++) {
        var n4 = nodes[i];
        var titleMatch = n4.title.toLowerCase().indexOf(q) >= 0 ? 2 : -1;
        var descMatch = (n4.description || '').toLowerCase().indexOf(q) >= 0 ? 1 : -1;
        var score = Math.max(titleMatch, descMatch);
        if (score > 0) matches.push({ n: n4, score: score });
      }
      matches.sort(function(a, b) { return b.score - a.score; });
      matches = matches.slice(0, 8);

      if (matches.length === 0) {
        results.innerHTML = '<div class="search-result" style="cursor:default;color:var(--color-text-muted);">No matches</div>';
        results.hidden = false;
        applySearchHighlight(null);
        return;
      }

      var escQ = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      var html = '';
      for (var k = 0; k < matches.length; k++) {
        var m = matches[k];
        var title = m.n.title.replace(/[<>&"]/g, function(c) { return ({ '<':'&lt;', '>':'&gt;', '&':'&amp;', '"':'&quot;' })[c]; });
        var re = new RegExp('(' + escQ + ')', 'gi');
        var highlighted = title.replace(re, '<mark>$1</mark>');
        html += '<a class="search-result" data-id="' + m.n.id + '" href="' + m.n.url + '">' +
          '<span class="res-dot" style="background:' + colorFor(m.n.collection) + ';"></span>' +
          '<span class="res-title">' + highlighted + '</span>' +
          '<span class="res-degree">' + (m.n.degree || 0) + '</span>' +
          '</a>';
      }
      results.innerHTML = html;
      results.hidden = false;
      applySearchHighlight(matches.map(function(m) { return m.n.id; }));
      currentFocus = -1;
    }

    if (search) {
      search.addEventListener('input', function() { showResults(search.value); });
      search.addEventListener('focus', function() { if (search.value) showResults(search.value); });
      search.addEventListener('blur', function() { setTimeout(function() { results.hidden = true; }, 200); });
      search.addEventListener('keydown', function(e) {
        var items = results.querySelectorAll('.search-result[data-id]');
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          currentFocus = Math.min(items.length - 1, currentFocus + 1);
          items.forEach(function(it, i) { it.classList.toggle('is-focused', i === currentFocus); });
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          currentFocus = Math.max(0, currentFocus - 1);
          items.forEach(function(it, i) { it.classList.toggle('is-focused', i === currentFocus); });
        } else if (e.key === 'Enter' && currentFocus >= 0) {
          if (items[currentFocus]) items[currentFocus].click();
        } else if (e.key === 'Escape') {
          search.value = '';
          results.hidden = true;
          applySearchHighlight(null);
        }
      });
    }

    // === Preview card ===
    var preview = document.getElementById('graph-preview');
    var previewTitle = document.getElementById('preview-title');
    var previewDesc = document.getElementById('preview-description');
    var previewCol = document.getElementById('preview-collection');
    var previewDegree = document.getElementById('preview-degree');
    var previewLink = document.getElementById('preview-link');
    var previewClose = document.getElementById('preview-close');
    function showPreview(n) {
      previewCol.textContent = (collectionStyles[n.collection] && collectionStyles[n.collection].label) || n.collection;
      previewCol.style.color = colorFor(n.collection);
      previewCol.style.borderColor = colorFor(n.collection);
      previewTitle.textContent = n.title;
      previewDesc.textContent = n.description || 'No description available.';
      previewDegree.textContent = (n.degree || 0) + ' connection' + (n.degree === 1 ? '' : 's');
      previewLink.href = n.url;
      preview.hidden = false;
    }
    function hidePreview() { preview.hidden = true; }
    if (previewClose) previewClose.addEventListener('click', hidePreview);

    // === Hubs panel toggle ===
    var hubsEl = document.getElementById('graph-hubs');
    var hubsToggle = document.getElementById('hubs-toggle');
    if (hubsEl && hubsToggle) {
      hubsToggle.addEventListener('click', function() {
        var collapsed = hubsEl.classList.toggle('is-collapsed');
        hubsToggle.setAttribute('aria-expanded', String(!collapsed));
        hubsToggle.textContent = collapsed ? '⊞' : '×';
      });
    }

    // === Hub list clicks ===
    var hubLinks = document.querySelectorAll('.hub-link');
    hubLinks.forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var id = link.getAttribute('data-id');
        var n6 = nodeById[id];
        if (!n6) return;
        // Center on node
        scale = 1.5;
        viewX = n6.x - viewWidth / scale / 2;
        viewY = n6.y - viewHeight / scale / 2;
        requestRender();
        setTimeout(function() { window.location.href = n6.url; }, 300);
      });
    });

    // === Minimap (canvas, lightweight) ===
    var minimapCanvas = document.getElementById('minimap-canvas');
    var mmCtx = minimapCanvas ? minimapCanvas.getContext('2d') : null;
    var MM_W = 200, MM_H = 130, MM_PAD = 6;
    function drawMinimap() {
      if (!mmCtx) return;
      mmCtx.clearRect(0, 0, MM_W, MM_H);
      // Background
      mmCtx.fillStyle = THEME.bg;
      mmCtx.fillRect(0, 0, MM_W, MM_H);
      var sX = (MM_W - MM_PAD*2) / 1200;
      var sY = (MM_H - MM_PAD*2) / 700;
      // Edges
      mmCtx.strokeStyle = 'rgba(110,110,110,0.4)';
      mmCtx.lineWidth = 0.4;
      for (var i = 0; i < edges.length; i++) {
        var a = nodeById[edges[i].source];
        var b = nodeById[edges[i].target];
        if (!a || !b) continue;
        mmCtx.beginPath();
        mmCtx.moveTo(MM_PAD + a.x * sX, MM_PAD + a.y * sY);
        mmCtx.lineTo(MM_PAD + b.x * sX, MM_PAD + b.y * sY);
        mmCtx.stroke();
      }
      // Nodes
      for (var j = 0; j < nodes.length; j++) {
        var n = nodes[j];
        mmCtx.beginPath();
        mmCtx.arc(MM_PAD + n.x * sX, MM_PAD + n.y * sY, Math.max(0.8, sizeFor(n.degree) * 0.4), 0, Math.PI * 2);
        mmCtx.fillStyle = colorFor(n.collection);
        mmCtx.fill();
      }
      // Viewport rect
      var vw = (viewWidth / scale) * sX;
      var vh = (viewHeight / scale) * sY;
      mmCtx.strokeStyle = '#2d4a3a';
      mmCtx.lineWidth = 1.5;
      mmCtx.strokeRect(MM_PAD + viewX * sX, MM_PAD + viewY * sY, vw, vh);
    }
    // Re-draw minimap when graph changes
    var origRequestRender = requestRender;
    function updateMinimap() { drawMinimap(); }
    // Hook into requestRender by wrapping (lightweight)
    // (already handled: render() only updates main canvas; we update minimap separately)

    // Initial minimap draw + on every request
    drawMinimap();
    // Wrap requestRender to also update minimap
    var _rR = requestRender;
    requestRender = function() {
      _rR();
      // Don't draw minimap on every frame; do it throttled
      if (window.__mmT) clearTimeout(window.__mmT);
      window.__mmT = setTimeout(drawMinimap, 80);
    };
    // Call once to redraw minimap
    requestRender();

    // Click minimap to jump
    if (minimapCanvas) {
      minimapCanvas.addEventListener('click', function(e) {
        var r = minimapCanvas.getBoundingClientRect();
        var sX = (MM_W - MM_PAD*2) / 1200;
        var sY = (MM_H - MM_PAD*2) / 700;
        var mx = e.clientX - r.left - MM_PAD;
        var my = e.clientY - r.top - MM_PAD;
        viewX = mx / sX - (viewWidth / scale) / 2;
        viewY = my / sY - (viewHeight / scale) / 2;
        requestRender();
      });
    }

    // === Resize observer ===
    if (window.ResizeObserver) {
      var ro = new ResizeObserver(function() {
        resize();
        requestRender();
      });
      ro.observe(container);
    }
    window.addEventListener('resize', function() { resize(); requestRender(); });

    // === Auto-hide hint ===
    var hint = document.getElementById('graph-hint');
    if (hint) {
      setTimeout(function() { hint.classList.add('hidden'); }, 6000);
      canvas.addEventListener('pointerdown', function() { hint.classList.add('hidden'); }, { once: true });
    }

    // === Visibility API: pause render when hidden ===
    document.addEventListener('visibilitychange', function() {
      if (!document.hidden) requestRender();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
})();
</script>
