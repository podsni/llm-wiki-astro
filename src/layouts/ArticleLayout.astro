---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ArticleMeta from '../components/ArticleMeta.astro';
import Backlinks from '../components/Backlinks.astro';
import Related from '../components/Related.astro';
import References from '../components/References.astro';
import CopyLink from '../components/CopyLink.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getEntryUrl, COLLECTION_LABELS } from '../utils/content';
import { formatDate, readingTime } from '../utils/format';

interface Props {
  collection: string;
  entry: any;
  bodyText: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { collection, entry, bodyText, headings } = Astro.props;
const url = getEntryUrl(collection, entry.id);
const collectionLabel = COLLECTION_LABELS[collection as keyof typeof COLLECTION_LABELS];
const minutes = readingTime(bodyText);
const aliases = entry.data.aliases ?? [];
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={entry.data.image}>
  <div class="article-layout">
    <aside class="article-sidebar">
      <Sidebar activeSlug={`${collection}/${entry.id}`} activeCollection={collection} />
    </aside>

    <article class="article-main">
      <Breadcrumb collection={collection} collectionLabel={collectionLabel} title={entry.data.title} />
      <header class="article-header">
        <span class="category-chip">{collectionLabel}</span>
        <h1 class="article-title">{entry.data.title}</h1>
        {entry.data.description && <p class="article-description">{entry.data.description}</p>}
        <ArticleMeta entry={entry} minutes={minutes} />
        {aliases.length > 0 && (
          <div class="alias-list">
            Also known as: {aliases.map((a: string) => <span>{a}</span>).reduce((acc: any[], x: any, i: number) => i === 0 ? [x] : [...acc, ', ', x], [])}
          </div>
        )}
        <div style="margin-top: var(--sp-3); display: flex; gap: var(--sp-2); align-items: center;">
          <CopyLink url={url} />
        </div>
      </header>

      <div class="article-content">
        <slot />
      </div>

      <Backlinks slug={entry.id} collection={collection} />
      <Related related={entry.data.related ?? []} />
      <References references={entry.data.references ?? []} />
    </article>

    <aside class="article-toc">
      <TableOfContents headings={headings} />
    </aside>
  </div>
</BaseLayout>
